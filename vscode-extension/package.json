{
    "name": "gatekeeper-remote-approval",
    "displayName": "GateKeeper - Remote Command Approval",
    "description": "Route VS Code Copilot command approvals to your phone via Telegram, Slack, or other channels",
    "version": "2.1.2",
    "publisher": "technologica",
    "icon": "icon.png",
    "repository": {
        "type": "git",
        "url": "https://github.com/sandeep-patel/gatekeeper"
    },
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Machine Learning",
        "Chat"
    ],
    "keywords": [
        "copilot",
        "ai",
        "approval",
        "telegram",
        "remote",
        "security",
        "mcp"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "gatekeeper",
                    "title": "GateKeeper",
                    "icon": "$(shield)"
                }
            ]
        },
        "views": {
            "gatekeeper": [
                {
                    "id": "gatekeeper.mainView",
                    "name": "GateKeeper",
                    "type": "webview"
                }
            ]
        },
        "commands": [
            {
                "command": "gatekeeper.setup",
                "title": "GateKeeper: Setup",
                "icon": "$(gear)"
            },
            {
                "command": "gatekeeper.configure",
                "title": "GateKeeper: Configure"
            },
            {
                "command": "gatekeeper.testConnection",
                "title": "GateKeeper: Test Connection"
            },
            {
                "command": "gatekeeper.enable",
                "title": "GateKeeper: Enable"
            },
            {
                "command": "gatekeeper.disable",
                "title": "GateKeeper: Disable"
            },
            {
                "command": "gatekeeper.showLogs",
                "title": "GateKeeper: Show Logs"
            },
            {
                "command": "gatekeeper.startBot",
                "title": "GateKeeper: Start Server"
            },
            {
                "command": "gatekeeper.runWithApproval",
                "title": "GateKeeper: Run Command with Approval"
            },
            {
                "command": "gatekeeper.managePatterns",
                "title": "GateKeeper: Manage Auto-Approve Patterns"
            }
        ],
        "configuration": {
            "title": "GateKeeper - Remote Command Approval",
            "properties": {
                "gatekeeper.enabled": {
                    "type": "boolean",
                    "default": false,
                    "description": "Enable remote command approval"
                },
                "gatekeeper.serverUrl": {
                    "type": "string",
                    "default": "http://localhost:8765",
                    "description": "URL of the GateKeeper approval server"
                },
                "gatekeeper.timeoutSeconds": {
                    "type": "number",
                    "default": 300,
                    "description": "Timeout in seconds for approval requests"
                },
                "gatekeeper.localApprovalDelay": {
                    "type": "number",
                    "default": 10,
                    "description": "Seconds to wait for local (VS Code) approval before escalating to Telegram"
                },
                "gatekeeper.autoApprovePatterns": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [],
                    "description": "Regex patterns for commands to auto-approve (e.g., '^ls\\b', '^pwd$')"
                },
                "gatekeeper.botPath": {
                    "type": "string",
                    "default": "",
                    "description": "Path to the GateKeeper bot directory"
                },
                "gatekeeper.chatId": {
                    "type": "string",
                    "default": "",
                    "description": "Your Telegram Chat ID (get this by sending /start to your bot)"
                },
                "gatekeeper.httpPort": {
                    "type": "number",
                    "default": 8765,
                    "description": "Port for the local approval HTTP server"
                },
                "gatekeeper.mcpEnabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Whether to use MCP server integration (recommended)"
                },
                "gatekeeper.preventSleep": {
                    "type": "boolean",
                    "default": true,
                    "description": "Prevent macOS from sleeping while the server is running (uses caffeinate)"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./ && npm run bundle:mcp",
        "compile:extension": "tsc -p ./",
        "bundle:mcp": "esbuild src/mcpServer.ts --bundle --platform=node --target=node18 --outfile=out/mcpServer.js --format=cjs",
        "watch": "tsc -watch -p ./",
        "lint": "eslint src --ext ts"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "@types/vscode": "^1.85.0",
        "@typescript-eslint/eslint-plugin": "^6.0.0",
        "@typescript-eslint/parser": "^6.0.0",
        "@vscode/vsce": "^3.9.1",
        "esbuild": "^0.28.0",
        "eslint": "^8.0.0",
        "typescript": "^5.0.0"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.29.0",
        "jsonc-parser": "^3.3.1",
        "node-fetch": "^3.3.0"
    },
    "allowScripts": {
        "esbuild@0.28.0": true
    }
}
